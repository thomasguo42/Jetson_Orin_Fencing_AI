# Optional knobs for the Docker BACKUP deployment (deploy/compose.yml).
# Copy to deploy/.env and edit. The PRIMARY bare-systemd path
# (deploy/README.md「主路径」) does NOT use this file.

# Image tag for pistelink/backend:<TAG>.
TAG=latest

# Build-time mirrors. Defaults are China mirrors (good for a domestic network).
# For an international build, point these back at the official sources:
#   NPM_REGISTRY=https://registry.npmjs.org
#   PIP_INDEX_URL=https://pypi.org/simple
#   APT_MIRROR=deb.debian.org
NPM_REGISTRY=https://registry.npmmirror.com
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
APT_MIRROR=mirrors.aliyun.com
