# Pin the CH340 USB-serial adapter to a stable name /dev/ttyUSB-mcu so the
# config never depends on enumeration order. Install to /etc/udev/rules.d/.
# If several CH340 devices are present, add ATTRS{serial}=="..." to disambiguate.
# ModemManager can probe USB serial adapters during hotplug; the ignore flags
# keep it from briefly opening the MCU port before the backend reconnects.
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", SYMLINK+="ttyUSB-mcu", MODE="0660", GROUP="dialout", ENV{ID_MM_DEVICE_IGNORE}="1", ENV{ID_MM_PORT_IGNORE}="1", ENV{MTP_NO_PROBE}="1"
